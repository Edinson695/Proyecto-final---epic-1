#!/usr/bin/env bash
set -eo pipefail

TIMEOUT=30
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TESTS_DIR="$(dirname "$SCRIPT_DIR")"
AUTOGRADER_DIR="$(dirname "$TESTS_DIR")"
ROOT_DIR="${AUTOGRADER_DIR}"
HEADER_DIR="${TESTS_DIR}"
PROJECT_INCLUDE_DIR="${ROOT_DIR}/include"
TEST_INCLUDE_DIR="${TESTS_DIR}/include"
TEST_INCLUDE_ALGEBRA_DIR="${TEST_INCLUDE_DIR}/utec/algebra"
EIGEN_DIR=""
LOG_FILE="${SCRIPT_DIR}/clang-tidy.log"
CLANG_TIDY_BIN=""
CLANGXX_BIN=""

: > "$LOG_FILE"

log() {
    echo "$@" | tee -a "$LOG_FILE"
}

# Prefer the newest clang-tidy/clang++ available on the host.
for candidate in 20 19 18 17 16 15 14; do
    if [[ -z "$CLANG_TIDY_BIN" ]] && command -v "clang-tidy-${candidate}" >/dev/null 2>&1; then
        CLANG_TIDY_BIN="clang-tidy-${candidate}"
    fi
    if [[ -z "$CLANGXX_BIN" ]] && command -v "clang++-${candidate}" >/dev/null 2>&1; then
        CLANGXX_BIN="clang++-${candidate}"
    fi
done

if [[ -z "$CLANG_TIDY_BIN" ]] && command -v clang-tidy >/dev/null 2>&1; then
    CLANG_TIDY_BIN="clang-tidy"
fi
if [[ -z "$CLANGXX_BIN" ]] && command -v clang++ >/dev/null 2>&1; then
    CLANGXX_BIN="clang++"
fi

if [[ -z "$CLANG_TIDY_BIN" ]]; then
    log "Error: clang-tidy no esta instalado"
    exit 1
fi

if [[ -d "${ROOT_DIR}/third_party/eigen-3.4.0" ]]; then
    EIGEN_DIR="${ROOT_DIR}/third_party/eigen-3.4.0"
elif [[ -d "/usr/include/eigen3" ]]; then
    EIGEN_DIR="/usr/include/eigen3"
fi

# Keep compatibility with student headers copied as flat files in /tests.
mkdir -p "${TEST_INCLUDE_ALGEBRA_DIR}"
if [[ -f "${TESTS_DIR}/shape.h" && ! -f "${TEST_INCLUDE_ALGEBRA_DIR}/shape.h" ]]; then
    cp "${TESTS_DIR}/shape.h" "${TEST_INCLUDE_ALGEBRA_DIR}/shape.h"
fi
if [[ -f "${TESTS_DIR}/tensor_backend.h" && ! -f "${TEST_INCLUDE_ALGEBRA_DIR}/tensor_backend.h" ]]; then
    cp "${TESTS_DIR}/tensor_backend.h" "${TEST_INCLUDE_ALGEBRA_DIR}/tensor_backend.h"
fi

STD_FLAG="-std=c++23"
if [[ -n "$CLANGXX_BIN" ]]; then
    if ! printf 'int main() { return 0; }\n' | "$CLANGXX_BIN" -x c++ "$STD_FLAG" -fsyntax-only - >/dev/null 2>&1; then
        STD_FLAG="-std=c++20"
    fi
fi

# Force clang-tidy to use the newest installed libstdc++ headers (Ubuntu toolchain PPA case).
LIBSTDCPP_FLAGS=()
LATEST_LIBSTDCPP=""
if [[ -d "/usr/include/c++" ]]; then
    LATEST_LIBSTDCPP="$(ls -1 /usr/include/c++ 2>/dev/null | sort -V | tail -n1 || true)"
fi
if [[ -n "${LATEST_LIBSTDCPP}" && -d "/usr/include/c++/${LATEST_LIBSTDCPP}" ]]; then
    LIBSTDCPP_FLAGS+=(-isystem "/usr/include/c++/${LATEST_LIBSTDCPP}")
    LIBSTDCPP_FLAGS+=(-isystem "/usr/include/c++/${LATEST_LIBSTDCPP}/backward")

    GCC_MACHINE="$(gcc -dumpmachine 2>/dev/null || true)"
    if [[ -n "${GCC_MACHINE}" && -d "/usr/include/${GCC_MACHINE}/c++/${LATEST_LIBSTDCPP}" ]]; then
        LIBSTDCPP_FLAGS+=(-isystem "/usr/include/${GCC_MACHINE}/c++/${LATEST_LIBSTDCPP}")
    fi
fi

FILES=(
    "${SCRIPT_DIR}/clang_tidy.cpp"
)

REQUIRED_HEADERS=(
    "${HEADER_DIR}/shape.h"
    "${HEADER_DIR}/tensor_backend.h"
)

CLANG_TIDY_INCLUDE_FLAGS=(
    -I"${TESTS_DIR}"
    -I"${TEST_INCLUDE_DIR}"
    -I"${TEST_INCLUDE_ALGEBRA_DIR}"
    -I"${PROJECT_INCLUDE_DIR}"
    -I"${PROJECT_INCLUDE_DIR}/utec/algebra"
    -I"/autograder/submission"
    -I"/autograder/submission/include"
)
if [[ -n "$EIGEN_DIR" ]]; then
    CLANG_TIDY_INCLUDE_FLAGS+=(-I"${EIGEN_DIR}")
fi

EXIT_CODE=0
for header_file in "${REQUIRED_HEADERS[@]}"; do
    if [[ ! -f "$header_file" ]]; then
        log "Warning: archivo no encontrado - $header_file"
        EXIT_CODE=1
    fi
done

for fullpath in "${FILES[@]}"; do
    if [[ ! -f "$fullpath" ]]; then
        log "Warning: archivo no encontrado - $fullpath"
        EXIT_CODE=1
        continue
    fi

    log "Analizando $(basename "$fullpath") con ${CLANG_TIDY_BIN} (${STD_FLAG})..."
    if ! timeout "$TIMEOUT" "$CLANG_TIDY_BIN" "$fullpath" \
        --quiet \
        --config='{
            Checks: "clang-diagnostic-*,clang-analyzer-*",
            WarningsAsErrors: "*"
        }' \
        -- \
        -x c++ \
        "$STD_FLAG" \
        "${LIBSTDCPP_FLAGS[@]}" \
        "${CLANG_TIDY_INCLUDE_FLAGS[@]}" 2>&1 | tee -a "$LOG_FILE"; then
        if [[ "${PIPESTATUS[0]}" -eq 124 ]]; then
            log "Timeout excedido al analizar $(basename "$fullpath")"
        fi
        EXIT_CODE=1
    fi
done

if [[ "$EXIT_CODE" -eq 0 ]]; then
    log "Clang-Tidy: todos los checks pasaron"
else
    log "Clang-Tidy: se encontraron problemas"
fi

gzip -f "$LOG_FILE"

exit "$EXIT_CODE"
